{
  "title": "Hotel Voice Agent - Overview",
  "uid": "hotel-voice-overview",
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Voice Sessions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "hotel_active_voice_sessions",
          "legendFormat": "Active Sessions"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": 0, "color": "green" },
            { "value": 50, "color": "yellow" },
            { "value": 100, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Voice Sessions / min",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(hotel_voice_sessions_total[1m]) * 60",
          "legendFormat": "Sessions/min"
        }
      ]
    },
    {
      "id": 3,
      "title": "OpenAI Tokens / hour",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "increase(hotel_llm_tokens_total[1h])",
          "legendFormat": "Tokens"
        }
      ]
    },
    {
      "id": 4,
      "title": "Service Requests by Type",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service_type) (hotel_service_requests_total)",
          "legendFormat": "{{service_type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Voice Turn Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hotel_voice_turn_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hotel_voice_turn_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(hotel_voice_turn_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "API Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(django_http_responses_total_by_status_view_method_total[1m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hotel_kafka_consumer_lag",
          "legendFormat": "{{topic}}-{{partition}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Database Query Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(hotel_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 DB latency"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "title": "Redis Memory Usage",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "OpenAI API Errors",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "rate(hotel_openai_errors_total[5m])",
          "legendFormat": "{{service}} {{error_type}}"
        }
      ]
    }
  ]
}
