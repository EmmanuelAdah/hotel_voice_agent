# ------------------------------------------------------------------
# Redirect HTTP → HTTPS
# ------------------------------------------------------------------

server {
    listen 80;
    server_name ${NGINX_SERVER_NAME};
    return 301 https://$host$request_uri;
}

# ------------------------------------------------------------------
# HTTPS Server
# ------------------------------------------------------------------

server {
    listen 443 ssl http2;
    server_name ${NGINX_SERVER_NAME};

    # ---------------------------------------------------------------
    # TLS
    # ---------------------------------------------------------------

    ssl_certificate     ${NGINX_SSL_CERT};
    ssl_certificate_key ${NGINX_SSL_KEY};

    ssl_protocols TLSv1.2 TLSv1.3;

    ssl_session_cache shared:SSL:20m;
    ssl_session_timeout 1d;

    ssl_prefer_server_ciphers off;

    ssl_stapling on;
    ssl_stapling_verify on;

    # ---------------------------------------------------------------
    # Security Headers
    # ---------------------------------------------------------------

    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Permissions-Policy "microphone=(self)" always;

    add_header Strict-Transport-Security \
        "max-age=31536000; includeSubDomains; preload" always;

    add_header X-Request-ID $request_id always;

    add_header Content-Security-Policy "
        default-src 'self';
        connect-src 'self' https: wss:;
        img-src 'self' data:;
        style-src 'self' 'unsafe-inline';
        script-src 'self';
    " always;

    # ---------------------------------------------------------------
    # Connection Limits
    # ---------------------------------------------------------------

    limit_conn conn_limit 20;

    client_max_body_size 10M;

    # ---------------------------------------------------------------
    # Static
    # ---------------------------------------------------------------

    location /static/ {
        alias /app/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location /media/ {
        alias /app/media/;
        expires 7d;
        add_header Cache-Control private;
    }

    # ---------------------------------------------------------------
    # Authentication
    # ---------------------------------------------------------------

    location ~ ^/api/v1/auth/ {
        limit_req zone=auth burst=3 nodelay;
        proxy_pass http://django_http;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # Voice API
    # ---------------------------------------------------------------

    location /api/v1/voice/ {
        limit_req zone=voice burst=5 nodelay;
        proxy_pass http://django_http;
        proxy_read_timeout 300s;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # WebSocket
    # ---------------------------------------------------------------

    location /ws/ {
        limit_req zone=voice burst=5;
        proxy_pass http://django_ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # Health
    # ---------------------------------------------------------------

    location /api/v1/health/ {

        access_log off;

        proxy_pass http://django_http;

        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # Metrics
    # ---------------------------------------------------------------

    location /metrics/ {

        allow ${PROMETHEUS_ALLOWED_NETWORK};
        deny all;

        proxy_pass http://django_http;

        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # API
    # ---------------------------------------------------------------

    location /api/ {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://django_http;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # ---------------------------------------------------------------
    # Django Admin
    # ---------------------------------------------------------------

    location /admin/ {

        allow ${ADMIN_ALLOWED_NETWORK};
        deny all;

        proxy_pass http://django_http;

        include /etc/nginx/conf.d/proxy_params.conf;
    }
}