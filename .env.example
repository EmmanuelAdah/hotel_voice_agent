# ════════════════════════════════════════════════════════════════════════════
# Hotel Voice Agent — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=hotel_agent.settings.production
DJANGO_SECRET_KEY=django-insecure-your-secret-key
JWT_SIGNING_KEY=change-me-another-long-random-key

ALLOWED_HOSTS=localhost,127.0.0.1,hotel-voice-agent.example.com
CORS_ALLOWED_ORIGINS=https://hotel-voice-agent.example.com,http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_NAME=hotel_agent
DB_USER=hotel_agent
DB_PASSWORD=strong-db-password-here
DB_HOST=postgres
DB_PORT=5432
DB_REPLICA_HOST=postgres   # Set to replica host in production

# ── Cache & Sessions (Redis) ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_CONSUMER_GROUP=hotel-agent-group
# For production with SASL_SSL:
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=your-api-key
# KAFKA_SASL_PASSWORD=your-api-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-api-key
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ── AWS S3 (media storage) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=hotel-agent-media
AWS_S3_REGION_NAME=eu-east-2
AWS_S3_ENDPOINT_URL=your-aws/supabase-url

# ── nginx certificates (SSL) ────────────────────────────────────────────────────────────────
NGINX_SERVER_NAME=hotel.example.com

SSL_CERTIFICATE=/etc/nginx/certs/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/nginx/certs/privkey.pem

PROMETHEUS_ALLOWED_NETWORK=your-allowed-network
ADMIN_ALLOWED_NETWORK=your-admin-allowed-network

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana-password
